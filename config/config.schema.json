{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/arturgrochau/macos-vim-navigation/config.schema.json",
  "title": "KeyDeck configuration",
  "description": "User config consumed by the Hammerspoon engine and written by the SwiftUI preset editor. Deep-merged over the engine defaults, so any subset of keys is valid.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "modifier": { "enum": ["cmd", "alt", "ctrl", "shift"] },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key"],
      "properties": {
        "mods": { "type": "array", "items": { "$ref": "#/definitions/modifier" } },
        "key": { "type": "string", "description": "Hammerspoon key name, e.g. 'h', 'space', 'f12', '='." }
      }
    }
  },
  "properties": {
    "preset": { "type": "string", "description": "Name of the active preset (informational)." },
    "debug": { "type": "boolean", "description": "Emit extra hs.alert diagnostics." },
    "customLua": { "type": "string", "description": "Raw Lua run after modules load (Developer Settings)." },
    "tuning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scrollStep": { "type": "number", "minimum": 1 },
        "scrollInitialDelay": { "type": "number", "minimum": 0 },
        "scrollRepeatInterval": { "type": "number", "minimum": 0 },
        "directionInitialDelay": { "type": "number", "minimum": 0 },
        "directionRepeatInterval": { "type": "number", "minimum": 0 },
        "dragMoveFrac": { "type": "number", "exclusiveMinimum": 0 },
        "globalCursorStep": { "type": "number", "minimum": 1 },
        "globalCursorHoldStep": { "type": "number", "minimum": 1 },
        "globalCursorRepeatDelay": { "type": "number", "minimum": 0 },
        "globalCursorRepeatInterval": { "type": "number", "minimum": 0 },
        "optionReleaseIdleSeconds": {
          "type": "number", "minimum": 0,
          "description": "The on-release, no-conflict guard: a bare Option tap only cycles screens after the keyboard has been idle this long."
        },
        "optionScrollAmount": { "type": "number", "minimum": 1 }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nav": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "activator": {
              "type": "object",
              "additionalProperties": false,
              "description": "Primary way to toggle NAV MODE.",
              "properties": {
                "kind": { "enum": ["tapModifier", "doubleTapModifier", "hotkey", "hyper", "capsLock"] },
                "modifier": { "enum": ["alt", "cmd", "ctrl", "shift", "rightAlt", "leftAlt", "rightCmd", "leftCmd", "rightCtrl", "leftCtrl"] },
                "onRelease": { "type": "boolean" },
                "hotkey": { "$ref": "#/definitions/binding" }
              }
            },
            "enterKeys": { "type": "array", "items": { "$ref": "#/definitions/binding" } },
            "exitKeys": { "type": "array", "items": { "$ref": "#/definitions/binding" } }
          }
        },
        "visual": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "enabled": { "type": "boolean" } }
        },
        "cursor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "mods": { "type": "array", "items": { "$ref": "#/definitions/modifier" } },
            "keys": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "left": { "type": "string" }, "down": { "type": "string" },
                "up": { "type": "string" }, "right": { "type": "string" },
                "click": { "type": "string" }
              }
            }
          }
        },
        "monitors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "skipVirtualDisplayPattern": {
              "type": "string",
              "description": "Pipe-separated name substrings; screens matching any are treated as virtual and skipped."
            },
            "optionTapCycle": { "type": "boolean", "description": "Tap cycleModifier alone (on release, idle-guarded) to move to the next display." },
            "cycleModifier": { "enum": ["alt", "ctrl", "cmd"], "description": "Modifier whose clean tap-and-release cycles displays. Default alt (Option)." },
            "optionScroll": { "type": "boolean" },
            "jumpKeys": { "type": "array", "items": { "type": "string" } },
            "jumpClickKeys": { "type": "array", "items": { "type": "string" } },
            "parkKeys": { "type": "array", "items": { "type": "string" } },
            "parkPadding": { "type": "number", "minimum": 0 },
            "focusLeft": { "$ref": "#/definitions/binding" },
            "focusRight": { "$ref": "#/definitions/binding" },
            "nextDisplay": { "$ref": "#/definitions/binding" },
            "prevDisplay": { "$ref": "#/definitions/binding" }
          }
        },
        "windows": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "hide": { "$ref": "#/definitions/binding" },
            "restore": { "$ref": "#/definitions/binding" }
          }
        }
      }
    },
    "apps": {
      "type": "array",
      "description": "Per-app launch/focus shortcuts (NAV MODE).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "bundleID"],
        "properties": {
          "key": { "type": "string" },
          "mods": { "type": "array", "items": { "$ref": "#/definitions/modifier" } },
          "bundleID": { "type": "string", "description": "macOS bundle identifier, e.g. com.openai.chat." },
          "names": { "type": "array", "items": { "type": "string" }, "description": "App display names used to find an already-running instance." },
          "clickTarget": { "enum": ["center", "bottom", "none"] },
          "exitNav": { "type": "boolean" }
        }
      }
    }
  }
}
